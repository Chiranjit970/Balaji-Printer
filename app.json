{
  "expo": {
    "name": "Balaji Printers",
    "slug": "balaji-printers",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "balajiprinters",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.balajiprinters.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.balajiprinters.app",
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "balajiprinters",
              "host": "orders"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-status-bar",
      "expo-font",
      "expo-secure-store",
      "expo-splash-screen",
      "expo-sharing"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "7355668f-b864-4ef9-a71f-0f5547f67ea1"
      }
    },
    "owner": "chiranslif"
  }
}
